# Server Configuration
PORT=3000
NODE_ENV=development

# CORS Configuration (comma-separated list of allowed frontend origins)
# Leave unset to allow all origins ("*"). For production, set this to your
# deployed frontend URL(s) so only your site can use the chat backend.
# Example:
# ALLOWED_ORIGINS=https://your-site.vercel.app,https://www.your-site.com
ALLOWED_ORIGINS=

# Socket.io Configuration (defaults are sensible; only change if needed)
SOCKET_PING_TIMEOUT=60000
SOCKET_PING_INTERVAL=25000
